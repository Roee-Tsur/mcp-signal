{
  "name": "mcp-signal",
  "version": "0.2.1",
  "description": "Tiny, zero-dependency, pluggable telemetry SDK for MCP widgets (Claude MCP Apps, ChatGPT Apps SDK, mcp-ui). Capture lifecycle, custom, and error events and forward them to any analytics destination.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-apps",
    "mcp-ui",
    "chatgpt-apps",
    "openai-apps",
    "apps-sdk",
    "claude",
    "openai",
    "widget",
    "iframe",
    "sandbox",
    "telemetry",
    "analytics",
    "product-analytics",
    "event-tracking",
    "instrumentation",
    "observability",
    "posthog",
    "webhook",
    "typescript"
  ],
  "license": "MIT",
  "author": "Roee Tsur <tsur.roee@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Roee-Tsur/mcp-signal.git"
  },
  "homepage": "https://github.com/Roee-Tsur/mcp-signal#readme",
  "bugs": {
    "url": "https://github.com/Roee-Tsur/mcp-signal/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/mcp-signal.global.js",
  "jsdelivr": "./dist/mcp-signal.global.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./inline": {
      "import": {
        "types": "./dist/inline.d.ts",
        "default": "./dist/inline.js"
      },
      "require": {
        "types": "./dist/inline.d.cts",
        "default": "./dist/inline.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "server": [
        "./dist/server.d.ts"
      ],
      "inline": [
        "./dist/inline.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "node scripts/embed-inline-source.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:bundle": "node scripts/check-bundle-leak.mjs",
    "check:package": "publint --strict && attw --pack .",
    "example": "npm run build && node example/server.mjs",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build && npm run check:bundle && npm run check:package"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "publint": "^0.3.21",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
